{
    "name":  "@kyberrock/desktop",
    "version":  "0.5.35",
    "private":  true,
    "type":  "module",
    "main":  "dist/main/main.js",
    "types":  "dist/index.d.ts",
    "scripts":  {
                    "build":  "node -e \"const fs=require(\u0027node:fs\u0027); fs.rmSync(\u0027dist\u0027,{recursive:true,force:true}); fs.rmSync(\u0027tsconfig.tsbuildinfo\u0027,{force:true})\" \u0026\u0026 tsc -b tsconfig.json \u0026\u0026 vite build --config vite.config.ts \u0026\u0026 node -e \"require(\u0027node:fs\u0027).cpSync(\u0027midia\u0027,\u0027dist/renderer/midia\u0027,{recursive:true})\" \u0026\u0026 node copy-workspace-packages.cjs",
                    "rebuild:native:electron":  "node rebuild-native-for-electron.cjs",
                    "dist:win":  "npm run build \u0026\u0026 npm run rebuild:native:electron \u0026\u0026 node -e \"const fs=require(\u0027fs\u0027); fs.rmSync(\u0027release/win-unpacked\u0027,{recursive:true,force:true}); fs.rmSync(\u0027release/builder-debug.yml\u0027,{force:true});\" \u0026\u0026 electron-builder --win --publish never \u0026\u0026 npm rebuild better-sqlite3",
                    "dev":  "vite --config vite.config.ts --host 0.0.0.0 --port 5174",
                    "start":  "npm run build \u0026\u0026 electron ."
                },
    "dependencies":  {
                         "@kyberrock/print-templates":  "0.1.0",
                         "@supabase/supabase-js":  "^2.107.0",
                         "better-sqlite3":  "^12.10.0",
                         "electron-updater":  "^6.8.9",
                         "lucide-react":  "^1.21.0",
                         "react":  "^19.2.7",
                         "react-dom":  "^19.2.7",
                         "recharts":  "^2.15.4"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.13",
                            "electron":  "40.10.2",
                            "electron-builder":  "^26.15.0"
                        },
    "build":  {
                  "appId":  "br.com.kyberrock.desktop",
                  "productName":  "KyberRock Desktop",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/**/*",
                                "package.json",
                                "midia/**/*"
                            ],
                  "publish":  [
                                  {
                                      "provider":  "generic",
                                      "url":  "https://updates.kyberrock.com/desktop/win"
                                  }
                              ],
                  "win":  {
                              "target":  "nsis",
                              "icon":  "midia/icon.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "perMachine":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "installerIcon":  "midia/icon.ico",
                               "uninstallerIcon":  "midia/icon.ico"
                           }
              }
}
