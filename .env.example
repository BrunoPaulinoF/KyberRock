# OMIE API Credentials
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
OMIE_APP_KEY=your_app_key_here
OMIE_APP_SECRET=your_app_secret_here

# Supabase frontend variables (EasyPanel / local dev)
VITE_SUPABASE_URL=https://vksihzfrgqoemcqpquit.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Supabase desktop variables (optional; installed app can also use local settings later)
SUPABASE_URL=https://vksihzfrgqoemcqpquit.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Supabase Edge Function secrets
# SUPABASE_SERVICE_ROLE_KEY is required only in Supabase Edge Functions; never expose it in frontend or desktop builds.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# KYBERROCK_ADMIN_PASSWORD_HASH = sha256(KYBERROCK_ADMIN_PASSWORD_SALT + plain_password)
KYBERROCK_ADMIN_USERNAME=admin
KYBERROCK_ADMIN_PASSWORD_SALT=change_this_random_salt
KYBERROCK_ADMIN_PASSWORD_HASH=sha256_hex_hash_here
KYBERROCK_ADMIN_SESSION_SECRET=change_this_long_random_secret
